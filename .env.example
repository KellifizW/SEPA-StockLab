# .env.example — 環境變數樣板
# 
# 使用說明：
#   1. 複製此檔案，改名為 `.env`
#   2. 填入你的實際值
#   3. 絕對不要 commit `.env` 到 git
#
# .env 已在 .gitignore 中，git 不會追蹤它

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot Configuration
# ─────────────────────────────────────────────────────────────────────────────
TG_BOT_TOKEN=你的Token_7123456789:AAGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_ADMIN_CHAT_ID=你的AdminChatID_400598958

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Mini App Configuration (ngrok tunnel)
# ─────────────────────────────────────────────────────────────────────────────
# 
# TG_MINI_APP_BASE_URL: Telegram Mini App 的公開 HTTPS 地址
#   • 使用 ngrok 隧道提供公開訪問（Telegram 要求 HTTPS）
#   • 格式: https://<your-ngrok-subdomain>.ngrok-free.dev
#   • 示例: https://kathaleen-cephalalgic-leonida.ngrok-free.dev
#
# **重要**: ngrok 免費帳號重啟時 URL 會改變，需要更新此環境變數
#
TG_MINI_APP_BASE_URL=https://your-ngrok-subdomain.ngrok-free.dev

# ─────────────────────────────────────────────────────────────────────────────
# ngrok Configuration (自動隧道)
# ─────────────────────────────────────────────────────────────────────────────
#
# 💡 ngrok AUTH TOKEN:
#   • 須在其他機器上配置: ngrok config add-authtoken <YOUR_TOKEN>
#   • Token 存儲位置: ~/.ngrok2/ngrok.yml (Linux/Mac) 或 
#                     %APPDATA%/ngrok/ngrok.yml (Windows)
#   • 不需要在 .env 中設置（ngrok 自動讀取）
#
# NGROK_AUTH_TOKEN=(此項不在 .env 中，由 ngrok 命令行配置)

